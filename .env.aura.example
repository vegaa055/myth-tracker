# Neo4j AuraDB credentials — copy this file to `.env.aura` and fill in.
#
# When you create an Aura instance it downloads a credentials .txt file.
# You can paste its contents here verbatim: the extra AURA_* lines are
# ignored, and NEO4J_USERNAME is accepted as well as NEO4J_USER.
#
# Then seed the cloud database with:   npm run seed:aura
#
# `.env.aura` is gitignored. Never commit real credentials.

NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=paste-the-generated-password-here
